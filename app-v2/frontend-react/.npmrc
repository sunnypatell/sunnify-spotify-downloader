# pnpm configuration
# Using pnpm as package manager (faster, better disk space usage)
# Install: curl -fsSL https://get.pnpm.io/install.sh | sh -

# Use strict module resolution
shamefully-hoist=false

# Only hoist built-in dependencies for better isolation
public-hoist-pattern=*
public-hoist-pattern=esbuild
public-hoist-pattern=lightningcss
