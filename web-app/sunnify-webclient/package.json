{
  "name": "sunnify-webclient",
  "version": "0.1.0",
  "private": true,
  "description": "Web client for Sunnify - fetch Spotify playlist and track metadata in the browser. Companion to the desktop downloader.",
  "keywords": [
    "spotify",
    "playlist",
    "music",
    "metadata",
    "nextjs",
    "react"
  ],
  "homepage": "https://sunnify-spotify-downloader.vercel.app",
  "repository": {
    "type": "git",
    "url": "https://github.com/sunnypatell/sunnify-spotify-downloader.git",
    "directory": "web-app/sunnify-webclient"
  },
  "author": {
    "name": "Sunny Jayendra Patel",
    "url": "https://github.com/sunnypatell"
  },
  "license": "SEE LICENSE IN ../../LICENSE",
  "bugs": {
    "url": "https://github.com/sunnypatell/sunnify-spotify-downloader/issues"
  },
  "engines": {
    "node": ">=20",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "cd ../.. && husky web-app/sunnify-webclient/.husky || true"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.0",
    "@radix-ui/react-dropdown-menu": "^2.1.1",
    "@radix-ui/react-icons": "^1.3.0",
    "@radix-ui/react-progress": "^1.1.0",
    "@radix-ui/react-scroll-area": "^1.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-switch": "^1.1.0",
    "@vercel/analytics": "^1.6.1",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "framer-motion": "^11.5.4",
    "lucide-react": "^0.439.0",
    "next": "15.5.19",
    "react": "^18",
    "react-dom": "^18",
    "react-hot-toast": "^2.4.1",
    "react-icons": "^5.3.0",
    "tailwind-merge": "^2.5.2",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "15.5.19",
    "husky": "^9.1.7",
    "lint-staged": "^15.3.0",
    "postcss": "^8",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  },
  "overrides": {
    "@typescript-eslint/parser": "^8",
    "@typescript-eslint/eslint-plugin": "^8"
  }
}
